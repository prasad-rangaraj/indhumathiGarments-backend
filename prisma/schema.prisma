// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Prisma seed configuration
// Run with: npm run prisma:seed

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(255)
  description String?  @db.Text
  price       Decimal  @db.Decimal(10, 2)
  image       String?  @db.VarChar(500)
  material    String   @db.VarChar(255)
  category    String   @db.VarChar(255)
  subcategory String   @db.VarChar(255)
  sizes       String   @db.Text // JSON array stored as string
  stock       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cartItems   CartItem[]
  orderItems  OrderItem[]
  reviews     Review[]
  wishlistItems WishlistItem[]

  @@index([category])
  @@index([subcategory])
  @@index([isActive])
}

model User {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(255)
  email     String   @unique @db.VarChar(255)
  phone     String?  @db.VarChar(20)
  password  String?  @db.VarChar(255) // nullable for guest users
  role      String   @default("customer") @db.VarChar(50) // customer, admin
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    Order[]
  cartItems CartItem[]
  wishlistItems WishlistItem[]
  reviews   Review[]
  addresses Address[]

  @@index([email])
  @@index([role])
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String   @db.VarChar(255) // Can be session ID for guests
  productId String
  quantity  Int      @default(1)
  size      String   @db.VarChar(50)
  color     String?  @db.VarChar(50)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([productId])
}

model WishlistItem {
  id        String   @id @default(uuid())
  userId    String   @db.VarChar(255)
  productId String
  createdAt DateTime @default(now())

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model Order {
  id            String   @id @default(uuid())
  orderId      String   @unique @db.VarChar(100)
  userId       String?  @db.VarChar(255)
  total        Decimal  @db.Decimal(10, 2)
  originalTotal Decimal? @db.Decimal(10, 2)
  discount     Decimal? @db.Decimal(10, 2)
  couponCode   String?  @db.VarChar(50)
  status       String   @default("Pending") @db.VarChar(50) // Pending, Packed, Shipped, Delivered, Cancelled
  trackingNumber String? @db.VarChar(100)
  paymentMethod String  @db.VarChar(50)
  
  // Customer Info (stored for guest orders)
  customerName  String  @db.VarChar(255)
  customerEmail String  @db.VarChar(255)
  customerPhone String  @db.VarChar(20)
  customerAddress String @db.Text
  customerCity   String  @db.VarChar(255)
  customerPincode String @db.VarChar(10)

  orderDate     DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  items         OrderItem[]

  @@index([userId])
  @@index([orderId])
  @@index([status])
  @@index([orderDate])
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId  String
  productId String
  quantity  Int
  size      String   @db.VarChar(50)
  color     String?  @db.VarChar(50)
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
}

model Review {
  id        String   @id @default(uuid())
  productId String
  userId    String?  @db.VarChar(255)
  name      String   @db.VarChar(255)
  rating    Int      // 1-5
  title     String?  @db.VarChar(255)
  content   String   @db.Text
  isApproved Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([userId])
  @@index([isApproved])
}

model Coupon {
  id          String   @id @default(uuid())
  code        String   @unique @db.VarChar(50)
  discount    Decimal  @db.Decimal(5, 2) // Percentage
  minAmount   Decimal? @db.Decimal(10, 2)
  maxDiscount Decimal? @db.Decimal(10, 2)
  validFrom   DateTime
  validUntil  DateTime
  isActive    Boolean  @default(true)
  usageLimit  Int?     // null = unlimited
  usedCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([code])
  @@index([isActive])
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique @db.VarChar(255)
  description String?  @db.Text
  image       String?  @db.VarChar(500)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
}

model Enquiry {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(255)
  email     String   @db.VarChar(255)
  phone     String?  @db.VarChar(20)
  subject   String   @db.VarChar(255)
  message   String   @db.Text
  status    String   @default("New") @db.VarChar(50) // New, Read, Replied, Closed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model Banner {
  id          String   @id @default(uuid())
  title       String   @db.VarChar(255)
  description String?  @db.Text
  image       String   @db.VarChar(500)
  link        String?  @db.VarChar(500)
  position    String   @db.VarChar(50) // hero, sidebar, footer, etc.
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([position])
}

model Address {
  id          String   @id @default(uuid())
  userId      String
  name        String   @db.VarChar(255)
  phone       String   @db.VarChar(20)
  address     String   @db.Text
  city        String   @db.VarChar(255)
  pincode     String   @db.VarChar(10)
  state       String   @db.VarChar(255)
  country     String   @default("India") @db.VarChar(255)
  isDefault   Boolean  @default(false)
  addressType String   @default("home") @db.VarChar(50) // home, work, other
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Settings {
  id            String   @id @default(uuid())
  key           String   @unique @db.VarChar(100)
  value         String   @db.Text // Encrypted for sensitive data
  isEncrypted   Boolean  @default(false)
  description   String?  @db.VarChar(255)
  updatedBy     String?  @db.VarChar(255)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([key])
}

