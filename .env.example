# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5001

# ─── Database ─────────────────────────────────────────────────────────────────
# Local PostgreSQL:
DATABASE_URL="postgresql://garments_user:YOUR_STRONG_PASSWORD@localhost:5432/indhumathi_garments"
# AWS RDS PostgreSQL:
# DATABASE_URL="postgresql://garments_user:PASS@your-rds-endpoint.us-east-1.rds.amazonaws.com:5432/indhumathi_garments"

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://yourdomain.com

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=YOUR_LONG_RANDOM_64_CHAR_HEX_SECRET

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# ─── Brevo Email (Sendinblue) ─────────────────────────────────────────────────
BREVO_API_KEY=YOUR_BREVO_API_KEY
BREVO_SENDER_EMAIL=youremail@gmail.com
BREVO_SENDER_NAME=Indhumathi Garments

# ─── Razorpay ─────────────────────────────────────────────────────────────────
# Use rzp_test_ prefix for development, rzp_live_ for production
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_SECRET